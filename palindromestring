#include<stdio.h>
int main(){
    char s[100];
    int l=0,flag=1;
    printf("Enter the string:");
    scanf("%s",s);
    while(s[l]!='\0'){
        l++;
    }
    for(int i=l-1;i>=0;i--){
        if(s[l-1-i]!=s[i]){
            flag=0;
            break;
        }
    }
    if(flag==1){
        printf("palindrome");
    }else{
        printf("not palindrome");
    }
}
