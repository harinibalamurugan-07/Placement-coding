#include<stdio.h>
#include<math.h>
int main(){
    int a;
    printf("Enter the number:");
    scanf("%d",&a);
    int original=a;
    int q=1,r,n2=0,n1,b=1;
    int digit=0;
    while(q!=0){
        q=a/10;
        a=q;
        digit++;
    }
    a=original;
    while(b!=0){
        b=a/10;
        r=a%10;
        n1=n2*10+r;
        n2=n1;
        a=b;
        
    }
    if(n2==original){
        printf("palindrome");
    }else{
        printf("not a palindrome");
    }
}
