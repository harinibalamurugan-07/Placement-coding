#include<stdio.h>
int main(){
    int a;
    printf("Enter the number:");
    scanf("%d",&a);
    int count=0;
    if(a==1){
        printf("%d is a prime number",a);
       return 0;
    }else{
        for(int i=2;i<a;i++){
            if (a%i==0){
                count++;
            }
        }
    }
    if(count>0){
        printf("%d is not prime number");
        
    }else{
        printf("%d is prime number");
    }

}
